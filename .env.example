# ====================================
# PRODUCTION ENVIRONMENT VARIABLES
# ====================================
# Copy this file to .env and replace placeholders with actual values
# Add these same variables to Vercel Dashboard → Settings → Environment Variables

# MongoDB Atlas Connection
MONGODB_URI=your_mongodb_connection_string_here

# AWS S3 Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here

# Application Configuration
NODE_ENV=production
FRONTEND_URL=https://your-vercel-url.vercel.app

# Frontend API URL
# For Vercel deployment (production): /api
# For local development: http://localhost:5001/api
VITE_API_URL=/api

# Google Sheets Apps Script URL
VITE_GOOGLE_SHEETS_URL=your_google_sheets_script_url_here

# ====================================
# LOCAL DEVELOPMENT (Optional)
# ====================================
# Uncomment and use these for local development:
# PORT=5001
# VITE_API_URL=http://localhost:5001/api
# MONGODB_URI=mongodb://localhost:27017/crystal-oil
